# Application
APP_NAME=BedaanWaves
APP_VERSION=1.0.0
DEBUG=True

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bedaanwaves_db
DATABASE_ECHO=False
DATABASE_POOL_SIZE=20

# API
API_V1_STR=/api/v1
API_HOST=0.0.0.0
API_PORT=3000

# CORS
CORS_ORIGINS=["http://localhost:3005", "http://localhost:3000"]

# External APIs
BRS_API_KEY=your_brs_api_key_here
BRS_API_BASE_URL=https://Api.BrsApi.ir
BRS_API_TIMEOUT=30
BRS_RATE_LIMIT_MAX_DAILY=50000
BRS_RATE_LIMIT_MAX_WINDOW=300
BRS_RATE_LIMIT_WINDOW_SECONDS=300

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
